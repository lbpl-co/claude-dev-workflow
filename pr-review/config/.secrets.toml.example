# Copy this file to .secrets.toml and fill in your values.
# .secrets.toml is gitignored — never commit it.

[ollama]
api_base = "http://localhost:11434"

[bitbucket]
username = ""       # Your Bitbucket username (not email)
app_password = ""   # Your Bitbucket App Password (scopes: pullrequest:read, pullrequest:write)
